{
  "info": {
    "_postman_id": "b7f2b1a8-9e85-4fa5-9b30-6f6b4e9a7b21",
    "name": "Postman API Testing - JSONPlaceholder",
    "description": "Collection thực hành kiểm thử API bằng Postman với các phương thức GET, POST, PUT, DELETE.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET - Get all posts",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/posts",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "posts"
          ]
        },
        "description": "Lấy danh sách bài viết."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response body is not empty\", function () {",
              "    pm.expect(pm.response.text()).to.not.be.empty;",
              "});",
              "",
              "pm.test(\"Response is an array\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "GET - Get post by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/posts/1",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "posts",
            "1"
          ]
        },
        "description": "Lấy chi tiết bài viết có ID = 1."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Post ID is 1\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.id).to.eql(1);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "POST - Create a new post",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Postman Test\",\n  \"body\": \"This is a test request using Postman\",\n  \"userId\": 1\n}"
        },
        "url": {
          "raw": "{{base_url}}/posts",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "posts"
          ]
        },
        "description": "Tạo mới một bài viết."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Response has an ID\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('id');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
