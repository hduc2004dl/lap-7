            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": 1,\n  \"title\": \"Updated Title\",\n  \"body\": \"This content has been updated using Postman\",\n  \"userId\": 1\n}"
        },
        "url": {
